{
  "name": "garage-rent-management-system",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "android:shell": "node scripts/build-native-shell.mjs",
    "android:add": "npm run android:shell && npx cap add android",
    "android:sync": "npm run android:shell && npx cap sync android",
    "android:open": "npx cap open android",
    "android:assets": "npx @capacitor/assets generate --android --iconBackgroundColor=#0f172a --iconBackgroundColorDark=#020617 --splashBackgroundColor=#0f172a --splashBackgroundColorDark=#020617",
    "android:apk": "npm run android:shell && npx cap build android --androidreleasetype APK"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.8",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.511.0",
    "next": "^14.2.35",
    "pdfkit": "^0.16.0",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^2.15.3",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@types/node": "^22.13.10",
    "@types/pdfkit": "^0.17.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
